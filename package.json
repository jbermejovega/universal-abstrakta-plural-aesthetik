{
  "name": "universal-abstrakta-plural-aesthetik",
  "version": "0.1.0",
  "description": "Plural SIGIL strata for WCAG-safe palette linting and PACA primitive generation.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "uap-palette": "./dist/cli.js",
    "uap-palette-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "docs",
    "README.md",
    "MCP.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "mcp": "node dist/mcp/server.js"
  },
  "keywords": [
    "wcag",
    "accessibility",
    "a11y",
    "color",
    "palette",
    "contrast",
    "monochrome",
    "mcp",
    "sigil",
    "paca",
    "wcag",
    "safe-replay",
    "presheaf",
    "sheaf",
    "graphical-calculus",
    "w3c",
    "pypi"
  ],
  "author": "jbermejovega",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbermejovega/universal-abstrakta-plural-aesthetik"
  },
  "homepage": "https://github.com/jbermejovega/universal-abstrakta-plural-aesthetik#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "accessible-color-palette": "^2.3.0"
  }
}
